    <preset name="Separate-Combined Background Train (Granular)" prefix="background-train-combined-granular">
        <include>
            <dataset stem="raw">background-train</dataset>
            <dataset stem="bass">background-train</dataset>
            <dataset stem="vocals">background-train</dataset>
            <dataset stem="drums">background-train</dataset>
            <dataset stem="other">background-train</dataset>
        </include>
        <hdbscan>
            <min_samples>5</min_samples>
            <min_cluster_size_min>5</min_cluster_size_min>
