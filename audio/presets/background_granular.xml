<?xml-model href="schema.xsd"?>
<presets>
    <preset name="Raw Background Train" prefix="background-train-raw-granular">
        <include>
            <dataset stem="raw">background-train</dataset>
        </include>
        <hdbscan>
            <min_samples>5</min_samples>
            <min_cluster_size_min>5</min_cluster_size_min>
            <min_cluster_size_max>20</min_cluster_size_max>
        </hdbscan>
        <normalize>
            <method>chunk</method>
            <method>band</method>
        </normalize>
    </preset>
    <preset name="Bass Background Train (Granular)" prefix="background-train-bass-granular">
        <include>
            <dataset stem="bass">background-train</dataset>
        </include>
        <hdbscan>
            <min_samples>5</min_samples>
            <min_cluster_size_min>5</min_cluster_size_min>
            <min_cluster_size_max>20</min_cluster_size_max>
        </hdbscan>
        <normalize>
            <method>chunk</method>
            <method>band</method>
        </normalize>
        <min_rms>-40</min_rms>
    </preset>
    <preset name="Vocals Background Train (Granular)" prefix="background-train-vocals-granular">
        <include>
