        </hdbscan>
        <normalize>
            <method>chunk</method>
            <method>band</method>
        </normalize>
        <min_rms>-40</min_rms>
    </preset>
    <preset name="Other Background Train (Granular)" prefix="background-train-other-granular">
        <include>
            <dataset stem="other">background-train</dataset>
        </include>
        <hdbscan>
            <min_samples>5</min_samples>
            <min_cluster_size_min>5</min_cluster_size_min>
